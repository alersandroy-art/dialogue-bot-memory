# Ключ API ProxyAPI (https://proxyapi.ru/)
OPENAI_API_KEY=your_openai_api_key_here

# Базовый URL прокси для OpenAI API
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1

# Ключ API Pinecone (https://www.pinecone.io/)
PINECONE_API_KEY=your_pinecone_api_key_here

# Имя индекса в Pinecone
PINECONE_INDEX_NAME=your_pinecone_index_name

# Модель LLM через ProxyAPI (OpenAI-совместимый формат)
LLM_MODEL=gpt-4o-mini

# Vision-модель для описания картинок собак (по умолчанию = LLM_MODEL)
VISION_MODEL=gpt-4o-mini

# Модель эмбеддингов через ProxyAPI
EMBEDDING_MODEL=text-embedding-3-small

# Токен Telegram-бота (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
