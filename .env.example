# Ключ API ProxyAPI (https://proxyapi.ru/)
OPENAI_API_KEY=your_openai_api_key_here

# Базовый URL прокси для OpenAI API
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1

# Ключ API Pinecone (https://www.pinecone.io/)
PINECONE_API_KEY=your_pinecone_api_key_here

# Имя индекса в Pinecone
PINECONE_INDEX_NAME=your_pinecone_index_name

# Модель LLM через ProxyAPI (OpenAI-совместимый формат)
LLM_MODEL=gpt-4o-mini

# Vision-модель для описания картинок собак (по умолчанию = LLM_MODEL)
VISION_MODEL=gpt-4o-mini

# Модель эмбеддингов через ProxyAPI
EMBEDDING_MODEL=text-embedding-3-small

# Токен Telegram-бота (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Опционально: прокси до api.telegram.org, если Telegram недоступен напрямую
# Примеры: http://127.0.0.1:7890  или  socks5://127.0.0.1:1080
# Для socks5: pip install "requests[socks]"
# TELEGRAM_PROXY=http://127.0.0.1:7890

# Уровень логов (DEBUG / INFO / WARNING / ERROR), файлы → logs/hay_v2_bot/
LOG_LEVEL=INFO

# Опционально: валидный токен Hugging Face для моделей Docling.
# Если в системе есть ПРОСРОЧЕННЫЙ token (ошибка 401 home-download) —
# либо обновите его, либо оставьте пустым: бот качает публичные модели анонимно.
# HF_TOKEN=
